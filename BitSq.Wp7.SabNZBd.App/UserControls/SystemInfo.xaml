<UserControl x:Class="BitSq.Wp7.SabNZBd.App.UserControls.SystemInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    d:DesignHeight="480" d:DesignWidth="480">

    <StackPanel Margin="0,20,0,0" x:Name="LayoutRoot">
        <Grid>
            <TextBlock Text="System" TextWrapping="Wrap" Margin="12,-6,12,0" Style="{StaticResource PhoneTextExtraLargeStyle}" />
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom" Text="Uptime: 2:22:21" TextWrapping="Wrap" Margin="12,-6,12,0" Style="{StaticResource PhoneTextSubtleStyle}"  />
        </Grid>
        <Grid Margin="12,2,0,4" Background="LightGray" Width="Auto" Height="2">
        </Grid>
        <TextBlock Text="{Binding VersionFriendly}" TextWrapping="Wrap" Margin="12,-6,12,0" Style="{StaticResource PhoneTextSubtleStyle}" Foreground="{StaticResource PhoneAccentBrush}" />
        <TextBlock Text="{Binding FreeSpaceFriendly}" TextWrapping="Wrap" Margin="12,-6,12,0" Style="{StaticResource PhoneTextSubtleStyle}" Foreground="{StaticResource PhoneAccentBrush}" />
    </StackPanel>
</UserControl>
