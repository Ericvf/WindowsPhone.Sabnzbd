<UserControl x:Class="BitSq.Wp7.SabNZBd.App.UserControls.QueueItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource PhoneFontFamilyNormal}"
    FontSize="{StaticResource PhoneFontSizeNormal}"
    Foreground="{StaticResource PhoneForegroundBrush}"
    d:DesignHeight="100" d:DesignWidth="450">

    <StackPanel x:Name="LayoutRoot">
        <TextBlock Text="{Binding Title}" TextWrapping="NoWrap" Style="{StaticResource PhoneTextExtraLargeStyle}" />
        <Grid Margin="12,2,0,4" Background="LightGray" Width="Auto" Height="8">
            <Rectangle Fill="{StaticResource PhoneAccentBrush}" Width="{Binding ProgressWidth}"  HorizontalAlignment="Left"  />
        </Grid>
        <Grid Margin="0,0,0,0">
            <TextBlock Text="{Binding StatusFriendly}" TextWrapping="Wrap" Style="{StaticResource PhoneTextSubtleStyle}" />
            <TextBlock Text="{Binding Percentage}" TextWrapping="Wrap" Style="{StaticResource PhoneTextSubtleStyle}" Foreground="{StaticResource PhoneAccentBrush}" VerticalAlignment="Stretch" HorizontalAlignment="Right" />
        </Grid>
    </StackPanel>
</UserControl>